# ── Telegram ──────────────────────────────────
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHANNEL_ID=-100xxxxxxxxxx       # Channel or group to post briefings
TG_OWNER_ID=your_telegram_user_id  # For admin notifications

# ── AI Provider (pick one) ────────────────────
AI_PROVIDER=claude                  # claude | openai | ollama
ANTHROPIC_API_KEY=sk-ant-xxx        # For Claude API
# OPENAI_API_KEY=sk-xxx             # For OpenAI
# OLLAMA_URL=http://localhost:11434  # For local Ollama

# ── AI Models ─────────────────────────────────
AI_MODEL_FILTER=claude-haiku-4-5    # Fast/cheap model for filtering
AI_MODEL_SUMMARY=claude-sonnet-4-6  # Smart model for summaries

# ── News APIs (optional, RSS is primary) ──────
# NEWSDATA_API_KEY=pub_xxx          # newsdata.io free tier
# WORLDNEWS_API_KEY=xxx             # worldnewsapi.com

# ── Schedule ──────────────────────────────────
CRON_SCHEDULE=0 8,12,18,22 * * *   # Default: 4x daily briefings
TIMEZONE=Asia/Kuala_Lumpur

# ── Options ───────────────────────────────────
TEMPLATES=crypto,ai-tech            # Comma-separated template names
MAX_ARTICLES_PER_RUN=50             # Max articles to process per cycle
LANGUAGE=zh                         # Briefing language: zh | en | both
